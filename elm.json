{
    "type": "package",
    "name": "Juli4nG/elm-json-render",
    "summary": "Native, fail-closed Elm renderer for json-render manifests",
    "license": "MIT",
    "version": "1.0.0",
    "exposed-modules": [
        "JsonRender",
        "JsonRender.Spec",
        "JsonRender.Expr",
        "JsonRender.Render"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/html": "1.0.0 <= v < 2.0.0",
        "elm/json": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {
        "avh4/elm-program-test": "4.0.0 <= v < 5.0.0",
        "elm-explorations/test": "2.0.0 <= v < 3.0.0"
    }
}
